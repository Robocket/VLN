<launch>
    <!-- 1. 启动ROS主节点（roscore，若已启动可省略） -->
    <!-- <node name="roscore" pkg="roslaunch" type="core" output="screen"/> -->

    <!-- 2. 启动图像发布节点（如USB摄像头，可选） -->
    <!-- <node name="usb_cam" pkg="usb_cam" type="usb_cam_node" output="screen">
        <param name="video_device" value="/dev/video0"/>
        <param name="image_width" value="640"/>
        <param name="image_height" value="480"/>
        <param name="pixel_format" value="yuyv"/>
    </node> -->

    <!-- 3. 启动YOLO检测节点 -->
    <node 
        name="yolo_detection_node"        
        pkg="yolo_detection_package"     
        type="yolo_detection_node.py"    
        output="screen"                  
        respawn="true"
        args="$(find yolo_detection_package)/scripts/yolo_detection_node.py">                  
        <!-- 可选：设置节点参数 -->
        <param name="confidence_threshold" value="0.5" type="double"/>
        <!-- 可选：话题重映射 -->
        <!-- <remap from="/camera/image_raw" to="/usb_cam/image_raw"/> -->
        
    </node>

    <!-- 4. 启动RViz可视化（可选） -->
    <!-- <node name="rviz" pkg="rviz" type="rviz" args="-d $(find yolo_detection_package)/config/yolo_detection.rviz" output="screen"/> -->
</launch>
